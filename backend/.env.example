# Copier ce fichier en .env et renseigner de vraies valeurs avant tout déploiement.
# En production, préférer des variables d'environnement injectées par la
# plateforme d'hébergement plutôt qu'un fichier .env committé.

PORT=4000
HOST=0.0.0.0
NODE_ENV=production

# --- JWT --------------------------------------------------------------
# Générer avec : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change-me-generate-a-real-random-secret
JWT_REFRESH_SECRET=change-me-generate-a-different-random-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# --- Base de données ----------------------------------------------------
DB_PATH=./data/yuki.sqlite

# --- Sauvegardes automatiques --------------------------------------------
BACKUP_DIR=./data/backups
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_COUNT=14

# --- Journalisation -------------------------------------------------------
LOG_DIR=./data/logs
LOG_LEVEL=info

# --- CORS -------------------------------------------------------------
# En production, restreindre à l'origine réelle de la PWA (ex. https://yukitraderpro.com (same-origin via proxy /api, voir netlify.toml.example))
CORS_ORIGIN=https://yukitraderpro.com

# --- Google Play Billing (Play Developer API) ----------------------------
# Compte de service créé dans Google Cloud Console, avec accès "Voir les
# rapports financiers" a minima dans Play Console > Utilisateurs et autorisations.
GOOGLE_PLAY_PACKAGE_NAME=com.yukitraderpro.app
GOOGLE_PLAY_SERVICE_ACCOUNT_EMAIL=play-billing@your-project.iam.gserviceaccount.com
GOOGLE_PLAY_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"

# --- Firebase Cloud Messaging (notifications push) ------------------------
FIREBASE_PROJECT_ID=yuki-trader-pro
FIREBASE_SERVICE_ACCOUNT_EMAIL=fcm-admin@yuki-trader-pro.iam.gserviceaccount.com
FIREBASE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"

# --- Scan planifié côté serveur (désactivé par défaut, voir Difficultés) --
SCHEDULED_SCAN_ENABLED=false
SCHEDULED_SCAN_INTERVAL_MINUTES=15
